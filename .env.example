# ====== ansimate – Umgebungskonfiguration ======
# Diese Datei nach ".env" kopieren und mit echten Werten fuellen.
# .env NICHT committen (steht in .gitignore).

# --- Datenbank ---
POSTGRES_USER=ansimate
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=ansimate

# --- Verschluesselung (Pflicht!) ---
# Starker, zufaelliger Schluessel. Ohne diesen verweigert das Backend den Start (fail-closed, B7).
# Erzeugen z. B.: openssl rand -base64 32
ENCRYPTION_KEY=CHANGE_ME_32_byte_random_key
SECRET_KEY=

# --- Sandbox (Pflicht!) ---
# ABSOLUTER Host-Pfad zum ./playbooks-Verzeichnis dieses Repos.
# Wird benoetigt, damit die Custom-Playbook-Sandbox sicher laeuft (B2).
# Beispiel Linux:   /opt/ansimate/devnet-ansible-webui/playbooks
# Beispiel Windows: C:\\repos\\devnet-ansible-webui\\playbooks  (bzw. der vom Docker-Daemon gesehene Pfad)
HOST_PLAYBOOKS_DIR=/ABSOLUTER/PFAD/zu/playbooks

# --- App / Domain ---
APP_DOMAIN=localhost
APP_BASE_URL=https://localhost
# ACME_EMAIL: NUR fuer die "Full"-Variante (docker-compose.yml) noetig – dort holt der mitgelieferte
# Traefik darueber Let's-Encrypt-Zertifikate. Die "Homelab"-Variante ignoriert diesen Wert (TLS macht
# dein bestehender Proxy).
ACME_EMAIL=admin@example.com
# COOKIE_SECURE: bei NUR-HTTP (kein TLS) auf false setzen, sonst sendet der Browser den
# Session-Cookie nicht -> Login schlaegt fehl. Mit TLS (empfohlen) auf true lassen.
COOKIE_SECURE=true

# --- Homelab-Variante (nur fuer docker-compose.homelab.yml) ---
# Bestehender externer Reverse-Proxy: Ansimate klinkt sich in DEIN vorhandenes Traefik-Netz ein,
# statt einen eigenen Traefik mitzubringen. Siehe Header von docker-compose.homelab.yml.
# Name deines bereits existierenden externen Docker-Netzes (z. B. das deines Traefik):
PROXY_NETWORK=proxy
# Traefik-Entrypoint, ueber den dein Proxy die App veroeffentlicht: web (HTTP) oder websecure (HTTPS):
TRAEFIK_ENTRYPOINT=web
# Image-Tag der Public-Images (ansimate/ce-backend|ce-frontend). Fuer Reproduzierbarkeit pinnen,
# z. B. ANSIMATE_TAG=v0.1.0; "latest" zieht jeweils die neueste Community-Version.
ANSIMATE_TAG=latest

# --- SMTP (E-Mail / 2FA) ---
SMTP_HOST=ssl0.ovh.net
SMTP_PORT=465
SMTP_USERNAME=postmaster@example.com
SMTP_PASSWORD=CHANGE_ME_smtp_password
SMTP_SENDER=postmaster@example.com

# --- CORS / Hosts ---
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- Rate Limiting / IP ---
IP_BLACKLIST=
IP_BAN_DURATION=86400
RATE_LIMIT_GLOBAL_IP=60
RATE_LIMIT_USER_IP=120
RATE_LIMIT_WHITELIST=127.0.0.1,::1

# --- Admin-Bootstrap ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# --- Sonstiges ---
