{
  "root": true,
  "env": {
    "browser": true,
    "node": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    "no-undef": "off",
    "no-unused-vars": "warn",
    "no-redeclare": "warn"
  },
  "overrides": [
    {
      "files": ["*.cjs"],
      "parserOptions": { "sourceType": "script" }
    }
  ]
}
