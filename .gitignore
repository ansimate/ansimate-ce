# Logs and runtime jobs history
logs/
playbooks/logs/
/tmp/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# OS files
.DS_Store
Thumbs.db

# Uploaded playbooks and temp playbook runs
playbooks/custom/
playbooks/tmp/

# Traefik ACME storage
letsencrypt/

# Graphify: lokaler Wissensgraph-Output ist ephemer und wird NICHT committet.
# Versioniert ist nur die geteilte Baseline docs/graphify.zip (per ./graphify_rebuild.sh).
graphify-out/
graphify-out.bak/

# GoBD/GDPdU: in backend/gdpdu/ werden zur Laufzeit Steuerexport-Testdaten erzeugt.
# Der gesamte Ordner darf NICHT versioniert werden (auch nicht das DTD-Asset; die Billing-/GoBD-
# Logik liest ihr DTD ohnehin aus backend/editions/billing/gdpdu/ und degradiert grazioes ohne).
backend/gdpdu/

# Community-Export-/Build-Artefakte (generiert via scripts/community-export.sh) - NICHT committen.
/build/



# Lokale Secrets / Umgebung
.env
*.env
!.env.example

# Branding: branding/ ist die committete, funktionsfaehige Standard-Vorlage.
# Die Standard-Assets (config.yml, Stylesheet, Logo, Favicon, Banner, Rechtstext-Vorlagen)
# werden getrackt. Per `node apply_preset.js <preset>` oder deploymentspezifisch ergaenzte
# Dateien (z.B. eigene favicon.ico, eigene Rechtstexte) bleiben ungetrackt.
/branding/*
!/branding/README.md
!/branding/config.yml
!/branding/config.yml.example
!/branding/style.css
!/branding/logo.svg
!/branding/favicon.svg
!/branding/banner.svg
!/branding/impressum.txt
!/branding/agb.txt
!/branding/dsgvo.txt
