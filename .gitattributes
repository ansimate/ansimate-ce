# Einheitliche Zeilenenden: alles als LF im Repository speichern.
* text=auto eol=lf

# Skripte & Configs müssen im Linux-Container zwingend LF haben
*.sh   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.py   text eol=lf
*.js   text eol=lf
*.conf text eol=lf

# Binärdateien nicht anfassen
*.png   binary
*.jpg   binary
*.svg   text eol=lf
*.ico   binary
*.woff2 binary
*.woff  binary
*.ttf   binary
*.eot   binary
